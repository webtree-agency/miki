# Payload secret (zufälligen langen String setzen)
PAYLOAD_SECRET=dev-secret-change-me

# Lokale SQLite (Dev)
DATABASE_URI=file:./payload.db

# Production Postgres (Vercel oder Supabase) – wenn gesetzt, überschreibt SQLite
# POSTGRES_URL=postgres://user:pass@host:5432/db

# Public site URL
NEXT_PUBLIC_SITE_URL=http://localhost:3000
